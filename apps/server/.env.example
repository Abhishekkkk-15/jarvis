# Jarvis Environment Variables Example

# AI Providers (At least one is required)
# Get your Groq API key at: https://console.groq.com/
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Get your NVIDIA NIM API key at: https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Database
# Format: postgres://user:password@localhost:5432/database_name
DATABASE_URL=postgres://postgres:postgres@localhost:5432/jarvis

# Server Configuration
PORT=3001
NODE_ENV=development

# Desktop Configuration
VITE_DEV_SERVER_URL=http://localhost:5173
